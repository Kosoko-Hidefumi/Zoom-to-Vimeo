# Zoom Server-to-Server OAuth credentials
ZOOM_ACCOUNT_ID=your_account_id_here
ZOOM_CLIENT_ID=your_client_id_here
ZOOM_CLIENT_SECRET=your_client_secret_here

# Zoom host user ID (email or "me")
ZOOM_USER_ID=me

# Download directory
DOWNLOAD_DIR=./downloads

# Timezone for date matching (JST)
TIMEZONE=Asia/Tokyo

# Vimeo upload (vimeo_upload.py) — Personal access token 等
# VIMEO_TOKEN=

# Optional: EU data residency accounts sometimes need:
# ZOOM_OAUTH_URL=https://zoom.eu/oauth/token
# ZOOM_API_BASE=https://api.eu.zoom.us/v2
